# === Discord ===
DISCORD_TOKEN=your_discord_bot_token_here

# === Provider Selection ===
# STT options:    whisper_local (free) | openai_whisper (paid)
STT_PROVIDER=whisper_local

# Translate options: google_free (free) | deepl (paid, free tier) | openai_gpt (paid)
TRANSLATE_PROVIDER=google_free

# === Language Settings ===
# Source language: auto = auto-detect, or use language code like en, zh, ja, ko
SOURCE_LANG=auto
# Target language code: zh=Chinese, en=English, ja=Japanese, ko=Korean, etc.
TARGET_LANG=zh

# === Whisper Local Settings ===
# Model size: tiny (fastest) | base | small | medium | large (most accurate)
# tiny=39MB, base=74MB, small=244MB, medium=769MB, large=1.5GB
WHISPER_MODEL=base

# === API Keys (only needed for paid providers) ===
OPENAI_API_KEY=
DEEPL_API_KEY=

# === Recording Settings ===
# How many seconds of audio to collect before processing (lower = more responsive but more API calls)
RECORDING_INTERVAL=5
# Minimum audio duration in seconds to process (filters out noise/silence)
MIN_AUDIO_SECONDS=0.5
